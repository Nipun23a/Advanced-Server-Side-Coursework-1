# =============================================================================
# Alumni Influencers Platform — Express API
# Environment Configuration
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Port the Express API listens on
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE (MySQL)
# Both the Express API and CodeIgniter app must point to the same database.
# -----------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=3306
DB_NAME=coursework1
DB_USER=root
DB_PASSWORD=your_database_password_here

# Maximum number of connections in the pool
DB_CONNECTION_LIMIT=10

# -----------------------------------------------------------------------------
# INTERNAL SERVICE AUTHENTICATION
# Used to authenticate requests from CodeIgniter → Express API.
# Must match the value stored via the Developer API Keys admin page.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------

INTERNAL_API_SECRET=replace_with_a_long_random_hex_string

# -----------------------------------------------------------------------------
# API KEY CONFIGURATION
# Controls the format of externally issued Bearer tokens.
# -----------------------------------------------------------------------------

# Length of the random part of the API key (characters)
API_KEY_LENGTH=64

# Prefix prepended to every generated API key (makes keys identifiable)
API_KEY_PREFIX=alum_

# -----------------------------------------------------------------------------
# RATE LIMITING
# All window values are in milliseconds.
# -----------------------------------------------------------------------------

# General rate limiter — applied to all routes
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Bidding rate limiter — applied to POST/PUT/DELETE bid routes
RATE_LIMIT_BID_WINDOW_MS=60000     # 1 minute
RATE_LIMIT_BID_MAX_REQUESTS=10

# Authentication rate limiter — applied to API key auth routes
RATE_LIMIT_AUTH_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# -----------------------------------------------------------------------------
# BIDDING CONFIGURATION
# Controls when bids close and how many times an alumni can be featured.
# -----------------------------------------------------------------------------

# Hour (24h) at which bidding closes each day (timezone below applies)
BID_CUTOFF_HOUR=18

# Minute at which bidding closes (0 = on the hour)
BID_CUTOFF_MINUTE=0

# Timezone for bid cutoff and cron job scheduling
# Must be a valid IANA timezone string: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
BID_TIMEZONE=Europe/London

# Maximum times an alumni can be featured per calendar month (standard)
MONTHLY_FEATURE_LIMIT=3

# Maximum times an alumni can be featured per month if they attended an event
MONTHLY_FEATURE_LIMIT_WITH_EVENT=4

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# Comma-separated list of allowed origins.
# -----------------------------------------------------------------------------

CORS_ORIGIN=http://localhost:8080,http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# LOGGING
# Winston logger configuration.
# Log levels: error | warn | info | http | verbose | debug | silly
# -----------------------------------------------------------------------------

LOG_LEVEL=debug
LOG_FILE=./src/logs/api.log

# -----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (SMTP)
# Used to notify winners and losers after daily winner selection.
# Leave SMTP_HOST blank to disable email notifications entirely.
# -----------------------------------------------------------------------------

# SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=your_smtp_host_here

# SMTP port — typically 587 (STARTTLS) or 465 (SSL)
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USER=your_smtp_username_or_email
SMTP_PASS=your_smtp_password_or_app_password

# The "From" address shown in outgoing emails
NOTIFICATION_FROM_EMAIL=noreply@eastminster.ac.uk
