# =============================================================================
# Alumni Influencers Platform — CodeIgniter 4 Web Application
# Environment Configuration
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# Set to 'production' on a live server to disable error display.
# Options: development | testing | production
# -----------------------------------------------------------------------------

CI_ENVIRONMENT = development

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# The full base URL of the CodeIgniter app (include trailing slash)
app.baseURL = http://localhost:8080/

# Set to true to force all requests to use HTTPS
# app.forceGlobalSecureRequests = false

# -----------------------------------------------------------------------------
# DATABASE (MySQL)
# Both the CodeIgniter app and Express API must point to the same database.
# -----------------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = coursework1
database.default.username = root
database.default.password = your_database_password_here
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# -----------------------------------------------------------------------------
# ENCRYPTION
# Used by CodeIgniter's encryption service (sessions, cookies).
# Generate a key with: php spark key:generate
# The value must be prefixed with hex2bin: if generated as hex.
# -----------------------------------------------------------------------------

encryption.key = hex2bin:replace_with_output_of_php_spark_key_generate

# -----------------------------------------------------------------------------
# SESSION
# Using the database handler so sessions persist across server restarts.
# The sessions table is created by the migration: 2026-04-05-180000_CreateSessionsTable
# -----------------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.cookieName = alumni_session
session.expiration = 7200
session.savePath = sessions
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

# -----------------------------------------------------------------------------
# INTERNAL API COMMUNICATION
# The URL of the Express API that CodeIgniter calls internally.
# Must NOT be publicly accessible — internal network only.
# -----------------------------------------------------------------------------

# Base URL of the Express API (no trailing slash)
INTERNAL_API_URL = http://localhost:3000

# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# Used to send email verification and password reset emails.
# Configure via CodeIgniter's Email service settings.
# -----------------------------------------------------------------------------

# Protocol: mail | smtp | sendmail
email.protocol = smtp

# SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
email.SMTPHost = your_smtp_host_here

# SMTP port — typically 587 (STARTTLS) or 465 (SSL)
email.SMTPPort = 587

# Encryption: tls | ssl | (empty for none)
email.SMTPCrypto = tls

# SMTP authentication credentials
email.SMTPUser = your_smtp_username_or_email
email.SMTPPass = your_smtp_password_or_app_password

# Sender details shown in outgoing emails
email.fromEmail = noreply@eastminster.ac.uk
email.fromName = Alumni Influencers Platform

# -----------------------------------------------------------------------------
# LOGGER
# 0=off, 1=emergency, 2=alert, 3=critical, 4=error,
# 5=warning, 6=notice, 7=info, 8=debug, 9=all
# -----------------------------------------------------------------------------

# logger.threshold = 4
